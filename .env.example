# Resend
RESEND_API_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=markupbuddy
R2_PUBLIC_URL=

# xAI (Grok) Image Generation
XAI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
